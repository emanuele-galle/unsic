      "parameters": {
        "method": "PATCH",
        "url": "={{ 'https://unsic.muscarivps.cloud/api/content/' + $('Extract Content Data').item.json.content_id }}",
        "authentication": "none",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  status: $json.publish_status,\n  platform_post_id: $json.platform_post_id,\n  published_at: $json.published_at\n}) }}",
        "options": {}
      },

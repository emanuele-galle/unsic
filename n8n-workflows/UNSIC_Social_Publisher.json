            {
              "id": "published_at",
              "name": "published_at",
              "type": "string",
              "value": "={{ $now.toISO() }}"
            },
            {
              "id": "api_response",
              "name": "api_response",
              "type": "object",
              "value": "={{ {success: true, platform: 'linkedin', message: 'LinkedIn API integration coming soon'} }}"

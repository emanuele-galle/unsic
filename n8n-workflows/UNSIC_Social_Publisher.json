{
  "name": "UNSIC Social Publisher",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "unsic-publish",
        "options": {}
      },
      "name": "Webhook Manual Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "unsic-publish",
      "id": "webhook-publish-1"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "name": "Schedule Trigger (Hourly)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 500],
      "id": "schedule-publish-1"
    },
    {
      "parameters": {
        "mode": "combine",
        "combinationMode": "mergeByPosition",
        "options": {}
      },
      "name": "Merge Triggers",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [500, 400],
      "id": "merge-triggers-1"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://unsic.muscarivps.cloud/api/content?status=ready",
        "authentication": "none",
        "options": {}
      },
      "name": "Get Scheduled Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [750, 400],
      "id": "http-get-content-1"
    },
    {
      "parameters": {
        "conditions": {
          "dateTime": [
            {
              "value1": "={{ $json.scheduled_for }}",
              "operation": "beforeOrEqual",
              "value2": "={{ $now.toISO() }}"
            }
          ]
        }
      },
      "name": "Filter Due for Publishing",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.2,
      "position": [1000, 400],
      "id": "filter-due-1"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "content_id",
              "name": "content_id",
              "type": "number",
              "value": "={{ $json.id }}"
            },
            {
              "id": "platform",
              "name": "platform",
              "type": "string",
              "value": "={{ $json.platform }}"
            },
            {
              "id": "content_text",
              "name": "content_text",
              "type": "string",
              "value": "={{ $json.content_text }}"
            },
            {
              "id": "content_image_url",
              "name": "content_image_url",
              "type": "string",
              "value": "={{ $json.content_image_url }}"
            },
            {
              "id": "hashtags",
              "name": "hashtags",
              "type": "array",
              "value": "={{ $json.hashtags }}"
            }
          ]
        },
        "options": {}
      },
      "name": "Extract Content Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1250, 400],
      "id": "set-extract-content-1"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.platform }}",
              "operation": "equals",
              "value2": "linkedin"

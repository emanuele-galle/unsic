      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [2500, 500],
      "id": "merge-updates-1"
    },
    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "fieldsToAggregate": {
          "fieldToAggregate": [
            {
              "fieldToAggregate": "platform",
              "renameField": true,
              "outputFieldName": "platforms_published"
            }
          ]
        },
        "options": {}
      },
      "name": "Aggregate Stats",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1.1,
      "position": [2750, 500],
      "id": "aggregate-stats-1"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "total_published",
              "name": "total_published",
              "type": "number",
              "value": "={{ $json.platforms_published ? $json.platforms_published.length : 0 }}"
            },
            {
              "id": "timestamp",
              "name": "timestamp",
              "type": "string",
              "value": "={{ $now.toISO() }}"
            },
            {
              "id": "summary",
              "name": "summary",
              "type": "object",
              "value": "={{ {\n  success: true,\n  total_published: $json.platforms_published ? $json.platforms_published.length : 0,\n  platforms: $json.platforms_published || [],\n  timestamp: $now.toISO()\n} }}"
            }
          ]
        },
        "options": {}
      },
      "name": "Build Summary",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [3000, 500],
      "id": "set-summary-publish-1"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json.summary) }}",
        "options": {}
      },
      "name": "Webhook Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [3250, 300],
      "id": "webhook-response-publish-1"
    },
    {
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_UNSIC_CHAT_ID || '123456789' }}",
        "text": "={{ '🚀 **UNSIC Social Publisher**\\n━━━━━━━━━━━━━━━\\n📊 Pubblicati: ' + $('Build Summary').item.json.total_published + '\\n🎯 Piattaforme: ' + $('Build Summary').item.json.summary.platforms.join(', ') + '\\n⏰ ' + $now.toFormat('dd/MM/yyyy HH:mm') }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "name": "Telegram Notification",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [3250, 500],
      "credentials": {
        "telegramApi": {
          "id": "telegram-unsic",
          "name": "UNSIC Telegram Bot"
        }
      },
      "id": "telegram-notify-1"
    }
